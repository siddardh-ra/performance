  "_note": "This file contains all expected OpenTelemetry metrics after migration from OpenCensus",

  "pipelines_controller": {
    "description": "Tekton Pipelines Controller metrics",
    "namespace": "openshift-pipelines",
    "component": "tekton-pipelines-controller",
    "metrics": [
      {
        "name": "tekton_pipelines_controller_pipelinerun_duration_seconds",
        "type": "histogram",
        "description": "Duration of PipelineRun execution in seconds",
        "labels": ["pipeline", "pipelinerun", "namespace", "status"],
        "suffixes": ["_bucket", "_sum", "_count"]
      },
      {
        "name": "tekton_pipelines_controller_pipelinerun_count",
        "type": "counter",
        "description": "Total count of PipelineRuns",
        "labels": ["status", "namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_running_pipelineruns_count",
        "type": "gauge",
        "description": "Number of PipelineRuns currently running",
        "labels": ["namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_taskrun_duration_seconds",
        "type": "histogram",
        "description": "Duration of TaskRun execution in seconds",
        "labels": ["task", "taskrun", "namespace", "status"],
        "suffixes": ["_bucket", "_sum", "_count"]
      },
      {
        "name": "tekton_pipelines_controller_taskrun_count",
        "type": "counter",
        "description": "Total count of TaskRuns",
        "labels": ["status", "namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_running_taskruns_count",
        "type": "gauge",
        "description": "Number of TaskRuns currently running",
        "labels": ["namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_running_taskruns_throttled_by_quota_count",
        "type": "gauge",
        "description": "Number of TaskRuns throttled by quota",
        "labels": ["namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_running_taskruns_throttled_by_node_count",
        "type": "gauge",
        "description": "Number of TaskRuns throttled by node constraints",
        "labels": ["namespace"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_taskruns_pod_latency_milliseconds",
        "type": "gauge",
        "description": "Latency between TaskRun creation and Pod scheduling in milliseconds",
        "labels": ["namespace", "pod", "task"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_workqueue_depth",
        "type": "gauge",
        "description": "Current depth of the controller workqueue",
        "labels": ["name"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_workqueue_adds_total",
        "type": "counter",
        "description": "Total number of items added to workqueue",
        "labels": ["name"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_workqueue_latency_seconds",
        "type": "histogram",
        "description": "Time items spend waiting in workqueue before being processed",
        "labels": ["name"],
        "suffixes": ["_bucket", "_sum", "_count"]
      },
      {
        "name": "tekton_pipelines_controller_workqueue_work_duration_seconds",
        "type": "histogram",
        "description": "Time taken to process items from workqueue",
        "labels": ["name"],
        "suffixes": ["_bucket", "_sum", "_count"]
      },
      {
        "name": "tekton_pipelines_controller_workqueue_unfinished_work_seconds",
        "type": "gauge",
        "description": "Time since oldest unfinished item was added to workqueue",
        "labels": ["name"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_workqueue_longest_running_processor_seconds",
        "type": "gauge",
        "description": "Duration of longest running workqueue processor",
        "labels": ["name"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_workqueue_retries_total",
        "type": "counter",
        "description": "Total number of retries for workqueue items",
        "labels": ["name"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_client_latency_seconds",
        "type": "histogram",
        "description": "Kubernetes API client request latency",
        "labels": ["verb", "group", "version", "resource"],
        "suffixes": ["_bucket", "_sum", "_count"]
      },
      {
        "name": "tekton_pipelines_controller_cloudevent_count",
        "type": "counter",
        "description": "Total cloud events sent",
        "labels": ["name", "type"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_cloudevent_sent_count",
        "type": "counter",
        "description": "Cloud events successfully sent",
        "labels": ["name", "type"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_reconcile_count",
        "type": "counter",
        "description": "Total reconciliation attempts",
        "labels": ["key", "success"],
        "suffixes": []
      },
      {
        "name": "tekton_pipelines_controller_reconcile_latency_seconds",
        "type": "histogram",
        "description": "Time taken for reconciliation",
        "labels": ["key"],
        "suffixes": ["_bucket", "_sum", "_count"]
      }
    ]
  },

